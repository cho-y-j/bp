<?xml version="1.0" encoding="utf-8"?>
<!-- 로그아웃/미인증 상태: 로그인 유도 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/workon_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/workon_widget_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/lo_brand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="작업온"
        android:textColor="@color/workon_orange"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/lo_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="로그인해 주세요"
        android:textColor="@color/workon_ink"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
