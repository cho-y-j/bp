// ============================================================================
//  작업온 (Jakeobon) — Prisma 스키마  (Stage 1)
//  근거: docs/DESIGN.md §5 데이터 모델 + docs/BUILD-PLAN.md S1 명세
//  DB: PostgreSQL 16 / 단일 모놀리식 (마이크로서비스 아님)
//
//  설계 원칙 요약
//   - 미가입 상대 허용: jobs/confirmations/ledger 의 상대방은 businessId(FK) 또는
//     수기 입력(상호명+연락처) 둘 다 허용 → 작업자 혼자서도 100% 동작.
//   - 증거력: safety_logs 와 서명 기록은 append-only(수정 금지), 시각은 서버 기준.
//   - 만료 관리: documents.expiryDate 인덱스 → 만료 임박 조회(D-30/7/0).
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
//  Enums
// ============================================================================

// 연결 상태 (작업자 ↔ 사업장)
enum ConnectionStatus {
  REQUESTED // 요청
  ACCEPTED // 수락
  REJECTED // 거절
}

// 연결 경로
enum ConnectionPath {
  PHONE_SEARCH // 전화번호 검색(동의자)
  INVITE_CODE // 사업장 초대코드
  QR // 현장 QR
  LINK // 공유 링크
}

// 서류 소유자 유형 (다형)
enum DocumentOwnerType {
  PROFILE // 프로필(개인) 소속 서류
  EQUIPMENT // 장비 소속 서류
}

// 서류 상태
enum DocumentStatus {
  ACTIVE // 유효
  EXPIRING // 만료 임박
  EXPIRED // 만료됨
  ARCHIVED // 보관(비활성)
}

// 단가 유형 (일당/시급/건당 + 확장)
enum RateType {
  DAILY // 일당
  HOURLY // 시급
  PER_CASE // 건당
  MONTHLY // 월급
  UNIT // 물량(㎥·톤 등) 단가
  GONGSU // 공수(품) — 1공수=하루 단가, 수량 소수 허용(0.5/1.5 등)
}

// 작업 지시/예약 상태
enum JobStatus {
  SCHEDULED // 예약됨
  IN_PROGRESS // 진행중
  DONE // 완료
  CANCELLED // 취소
}

// 확인서 상태 (SKEP 3단계 패턴 차용)
enum ConfirmationStatus {
  DRAFT // 작성됨
  SENT // 전송됨
  SIGNED // 서명됨
}

// 장부 상태
enum LedgerStatus {
  PENDING // 미수(대기)
  PARTIAL // 부분입금
  PAID // 완납
  OVERDUE // 연체
}

// 안전 로그 유형
enum SafetyLogType {
  HEAT_ALERT // 폭염 알림
  REST_GUIDE // 휴식 안내
  DOCUMENT_VALIDITY // 서류 유효 확인
  CONDITION_CHECK // 컨디션 체크
  TBM // 간편 TBM(안전점검회의) 기록·확인 (P2c)
}

// 알림 유형
enum NotificationType {
  PAYMENT_DUE // 수금 D-day
  DOCUMENT_EXPIRY // 서류 만료 D-30/7/0
  RESERVATION // 예약 확인
  HEAT_ALERT // 폭염
  CONFIRMATION // 확인서 관련(수신/서명)
  TBM // 간편 TBM(안전점검회의) 도착·확인 요청 (P2c)
}

// TBM 프리셋 분류 (사업장 커스텀 문구) — 위험요인 / 조치 (P2c)
enum TbmPresetKind {
  HAZARD // 위험요인
  MEASURE // 조치
}

// 디바이스 플랫폼 (FCM)
enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

// 표준근로계약서 상태 (P2b) — 확인서와 동일 3단계 패턴
enum LaborContractStatus {
  DRAFT // 작성됨 (사업장 편집 가능)
  SENT // 전송됨 (사업장 서명 완료 → 작업자 서명 대기)
  SIGNED // 서명됨 (양측 서명 완료)
}

// 임금 유형 (일용직 표준근로계약서) — 일급/시급
enum WageType {
  DAILY // 일급(일당)
  HOURLY // 시급
}

// ============================================================================
//  profiles — 사용자 (1 사용자 = 1 프로필)
// ============================================================================
model Profile {
  id                 String   @id @default(uuid())
  name               String? // 이름 (가입 직후엔 없음 → 온보딩에서 채움)
  phone              String   @unique // 전화(인증)
  kakaoId            String?  @unique // 카카오 로그인 식별자 (카카오 가입자만)
  phoneSearchConsent Boolean  @default(false) // 전화번호 검색 허용 동의 (법적 필수)
  industryTags       String[] @default([]) // 업종 태그
  // 세금계산서 공급자(내 사업자) 정보 — 홈택스 작성용. PATCH /me 로 등록.
  bizNumber          String? // 내 사업자등록번호 (세금계산서 공급자)
  bizName            String? // 내 상호(사업자명)
  bizAddress         String? // 내 사업장 주소
  // 수금 안내용 입금 계좌 (P3a, 선택 입력) — 독촉 안내 문구에 계좌 노출
  payoutBank         String? // 은행명
  payoutAccount      String? // 계좌번호
  payoutHolder       String? // 예금주
  // QR 명함 — 작업자 공개 프로필 (P3b)
  cardToken          String?  @unique // 공개 프로필 토큰(nanoid 32). 온보딩 후 최초 GET /me/card 시 생성.
  cardEnabled        Boolean  @default(true) // 공개 명함 노출 ON/OFF (false 면 공개 페이지 404)
  cardIntro          String? // 한 줄 소개 (공개 프로필에 노출)
  cardViewCount      Int      @default(0) // 공개 프로필 조회 수 (로그 최소화 — 카운터만)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // 관계
  ownedBusinesses Business[]      @relation("BusinessOwner")
  connections     Connection[]
  equipments      Equipment[]
  documents       Document[]
  documentShares  DocumentShare[]
  jobs            Job[]
  confirmations   Confirmation[]
  ledgerEntries   LedgerEntry[]
  safetyLogs      SafetyLog[]     @relation("SafetyTarget")
  notifications   Notification[]
  deviceTokens    DeviceToken[]
  teams           Team[]          @relation("TeamOwner") // 반장(팀장)으로서 소유한 팀
  teamMemberships TeamMember[]    @relation("TeamMemberProfile") // 가입자로서 소속된 팀원 항목
  workerContracts LaborContract[] @relation("LaborContractWorker") // 가입 작업자로서 받은 근로계약서 (P2b)
  tbmAttendances  TbmAttendee[]   @relation("TbmAttendeeProfile") // 가입 작업자로서 참석한 TBM (P2c)
  tbmAuthored     TbmRecord[]     @relation("TbmAuthor") // 작성한 TBM 기록 (P2c)

  @@index([phone])
  @@map("profiles")
}

// ============================================================================
//  businesses — 사업장 (사업장 모드)
// ============================================================================
model Business {
  id             String   @id @default(uuid())
  name           String // 상호
  businessNumber String? // 사업자번호 (선택)
  inviteCode     String   @unique // 초대코드 (6자리)
  ownerId        String
  address        String? // 현장/사업장 주소 (폭염 좌표 조회 참고용)
  lat            Float? // 위도 (폭염 기상 조회용, nullable)
  lng            Float? // 경도 (폭염 기상 조회용, nullable)
  // 지급 평판 배지 캐시 (P3a) — 검색마다 실시간 집계 금지, 일일 크론 + pay 시점 비동기 갱신.
  paymentAvgDays        Float? // 평균 지급 소요일(SIGNED→전액 PAID), 표본 3건 미만이면 null
  paymentSampleSize     Int      @default(0) // 최근 12개월 표본 수(전액 지급 완료 확인서)
  paymentBadgeUpdatedAt DateTime? // 배지 캐시 갱신 시각
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // 관계
  owner         Profile        @relation("BusinessOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  connections    Connection[]
  jobs           Job[]
  confirmations  Confirmation[]
  ledgerEntries  LedgerEntry[]
  safetyLogs     SafetyLog[]
  laborContracts LaborContract[] // 이 사업장이 발행한 표준근로계약서 (P2b)
  tbmRecords     TbmRecord[] // 이 사업장의 간편 TBM 기록 (P2c)
  tbmPresets     TbmPreset[] // 이 사업장의 TBM 프리셋 문구 (P2c)

  @@index([ownerId])
  @@map("businesses")
}

// ============================================================================
//  connections — 작업자 ↔ 사업장 연결
// ============================================================================
model Connection {
  id         String           @id @default(uuid())
  profileId  String // 작업자
  businessId String // 사업장
  status     ConnectionStatus @default(REQUESTED)
  path       ConnectionPath // 연결 경로
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([profileId, businessId])
  @@index([businessId])
  @@map("connections")
}

// ============================================================================
//  equipments — (장비 사용자) 장비
// ============================================================================
model Equipment {
  id            String   @id @default(uuid())
  profileId     String // 소속 프로필
  type          String // 종류 (예: 굴삭기, 지게차)
  vehicleNumber String? // 차량번호
  spec          String? // 규격 (예: 06W, 3.5톤)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile   Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([profileId])
  @@map("equipments")
}

// ============================================================================
//  documents — 서류 (소유자: 프로필 | 장비 다형)
//   - 만료 임박 조회를 위해 expiryDate 인덱스 (SKEP has_expiry 패턴)
//   - 공유는 마스킹본(maskedFilePath)으로만 → 원본 filePath 는 소유자 전용
// ============================================================================
model Document {
  id                 String            @id @default(uuid())
  ownerType          DocumentOwnerType // PROFILE | EQUIPMENT
  profileId          String? // ownerType=PROFILE 일 때
  equipmentId        String? // ownerType=EQUIPMENT 일 때
  type               String // 유형 (신분증/사업자등록증/자격증/장비검사증 등)
  filePath           String // 정규화본(PDF) 경로 — 열람/공유의 기준 파일
  maskedFilePath     String? // 주민번호 등 마스킹본 경로 (공유 기본값)
  originalFilePath   String? // 업로드 원본 파일 경로 (이미지→PDF 정규화 시 보존)
  originalFileName   String? // 업로드 당시 파일명 (다운로드 표시용)
  fileSize           Int? // 업로드 원본 바이트 크기
  mimeType           String? // 업로드 원본 MIME 타입
  issuedDate         DateTime? // 발급일
  expiryDate         DateTime? // 만료일 (nullable)
  status             DocumentStatus    @default(ACTIVE)
  verificationResult Json? // 진위확인 결과 (govapi 응답 등)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  profile   Profile?         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  equipment Equipment?       @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  sharedIn  SharedDocument[] // 공유 묶음에 포함된 항목 (명시적 조인)

  @@index([expiryDate]) // 만료 임박 조회 (D-30/7/0)
  @@index([profileId])
  @@index([equipmentId])
  @@map("documents")
}

// ============================================================================
//  document_shares — 선택 묶음 공유 (서류 체크 선택 → 링크)
//   - 선택된 문서들과 다대다 관계 (SharedDocuments)
//   - 유효기간 + 열람 로그(JSONB[])
//   - 마스킹 정책: 주민번호 등 민감정보 서류는 기본 마스킹본(masked_file_path)을
//     공유한다(useMasked=true). 공유 생성 시 서류별로 원본 노출을 선택할 수 있으며,
//     그 선택은 명시적 조인 모델 SharedDocument.useOriginal 플래그로 관리한다.
//     useMasked 는 이 공유 묶음의 기본값(마스킹본 우선 사용 여부)이다.
// ============================================================================
model DocumentShare {
  id         String   @id @default(uuid())
  ownerId    String // 공유를 만든 프로필
  shareToken String   @unique // 외부 링크 토큰
  expiresAt  DateTime // 유효기간
  useMasked  Boolean  @default(true) // 기본 마스킹본 공유 여부 (민감정보 서류 보호)
  revokedAt  DateTime? // 즉시 무효화 시각 (설정 시 링크 만료 처리)
  viewLogs   Json[]   @default([]) // 열람 로그 [{ ip, ua, at }] — 최근 50개만 유지
  viewCount  Int      @default(0) // 누적 열람 횟수 (viewLogs 는 cap 되므로 총계는 이 카운터로)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner     Profile          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  documents SharedDocument[] // 선택된 문서 묶음 (명시적 조인)

  @@index([ownerId])
  @@map("document_shares")
}

// ============================================================================
//  shared_documents — DocumentShare ↔ Document 명시적 조인 모델
//   - 암묵 M:N(_SharedDocuments) 을 승격해 서류별 원본/마스킹 선택을 담는다.
//   - useOriginal=true 면 그 서류만 마스킹 안 한 정규화본(원본)을 공유한다.
// ============================================================================
model SharedDocument {
  id              String   @id @default(uuid())
  documentShareId String
  documentId      String
  useOriginal     Boolean  @default(false) // true = 이 서류는 마스킹본 대신 원본(정규화본) 공유
  createdAt       DateTime @default(now())

  share    DocumentShare @relation(fields: [documentShareId], references: [id], onDelete: Cascade)
  document Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentShareId, documentId])
  @@index([documentId])
  @@map("shared_documents")
}

// ============================================================================
//  jobs — 작업 예약/지시
//   - 상대: businessId(FK) 또는 수기(manualCompanyName/manualContact)
// ============================================================================
model Job {
  id                String    @id @default(uuid())
  profileId         String // 작업자(수행자)
  businessId        String? // 지시 사업장 (가입 시)
  manualCompanyName String? // 수기 상호명 (미가입 상대)
  manualContact     String? // 수기 연락처
  site              String // 현장/장소
  scheduledAt       DateTime // 일시
  rateType          RateType // 단가 유형
  rate              Decimal   @db.Decimal(12, 2) // 단가
  overtimeRate      Decimal?  @db.Decimal(12, 2) // 연장 단가
  nightRate         Decimal?  @db.Decimal(12, 2) // 야간 단가
  status            JobStatus @default(SCHEDULED)
  acceptedAt        DateTime? // 작업자가 예약을 확인(수락)한 시각
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  profile       Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  business      Business?      @relation(fields: [businessId], references: [id], onDelete: SetNull)
  workLogs      WorkLog[]
  confirmations Confirmation[]

  @@index([profileId])
  @@index([businessId])
  @@index([scheduledAt])
  @@index([manualContact]) // 미가입 상대 승격 스캔 (manualContact 매칭)
  @@map("jobs")
}

// ============================================================================
//  work_logs — 수행 기록
// ============================================================================
model WorkLog {
  id             String    @id @default(uuid())
  jobId          String
  startedAt      DateTime? // 시작 시각
  finishedAt     DateTime? // 완료 시각
  gpsLat         Float? // GPS 위도
  gpsLng         Float? // GPS 경도
  photoPaths     String[]  @default([]) // 사진 경로들
  conditionCheck Json? // 컨디션 체크 결과
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("work_logs")
}

// ============================================================================
//  confirmations — 작업확인서 (공통 코어 + 장비 섹션)
//   - 외부 서명: shareToken 링크 → 웹 열람 → 이름 입력 + 터치 서명
//   - 서명 기록(signImagePath/signerName/signedAt)은 서버 시각 기준
// ============================================================================
model Confirmation {
  id               String   @id @default(uuid())
  profileId        String // 작성자(작업자)
  jobId            String? // 연결된 작업(선택)
  businessId       String? // 지시 사업장 (가입 시)
  companyName      String // 회사명(지시자) — 수기 포함
  date             DateTime // 날짜
  site             String // 현장/장소
  workContent      String // 작업 내용
  startTime        DateTime // 시작 시각
  endTime          DateTime // 종료 시각
  manualContact    String? // 수기 상대 연락처 (미가입 상대, businessId 없을 때)
  rateType         RateType // 단가 유형
  amountCalc       Json // 금액 계산 내역 { items:[{type,label,rate,quantity,amount}], subtotal, vatRate, vat, total }
  equipmentSection Json? // 장비 섹션 (장비명/차량번호/규격/유도원) — 장비 사용자만
  notes            String? // 특이사항

  // 팀(반장) 확인서 — teamId 있으면 팀 명단(teamEntries)로 합계 계산. 반장 장부에 합계 1건.
  teamId      String? // 반장이 지정한 팀 (P2a)
  teamEntries Json? // 팀원별 몫 [{ name, profileId?, quantity(공수), rate, amount }] — 서버 계산

  // 외부 서명 / 공개 링크
  shareToken    String             @unique // 외부 링크 토큰 (생성 시 발급)
  signImagePath String? // 서명 이미지 경로
  signerName    String? // 서명자 이름
  signedAt      DateTime? // 서명 시각 (서버 기준)
  revokedAt     DateTime? // 링크 무효화 시각 (설정 시 공개 열람 차단)
  viewLogs      Json[]             @default([]) // 공개 열람 로그 [{ at, ip, ua }] — 최근 50개만 유지
  viewCount     Int                @default(0) // 누적 열람 횟수 (viewLogs 는 cap 되므로 총계는 이 카운터로)
  status        ConfirmationStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile              Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  job                  Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  business             Business?     @relation(fields: [businessId], references: [id], onDelete: SetNull)
  team                 Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  ledgerEntry          LedgerEntry?  @relation("LedgerConfirmation")
  derivedLedgerEntries LedgerEntry[] @relation("LedgerSourceConfirmation") // 팀원 파생 장부 항목들

  @@index([profileId])
  @@index([status])
  @@index([profileId, date]) // 월별 캘린더 집계 (프로필 + 날짜)
  @@index([manualContact]) // 미가입 상대 승격 스캔 (manualContact 매칭)
  @@index([teamId]) // 팀별 확인서 조회
  @@map("confirmations")
}

// ============================================================================
//  ledger_entries — 장부 (받을 돈)
//   - 확인서 연결(선택) + 상대(사업장FK 또는 수기명)
//   - 부분입금 허용: payments JSONB[]
// ============================================================================
model LedgerEntry {
  id                   String       @id @default(uuid())
  profileId            String // 장부 소유자(작업자)
  confirmationId       String?      @unique // 연결된 확인서 (선택, 1:1)
  sourceConfirmationId String? // 팀원 파생 항목의 원 확인서(반장 팀 확인서) 참조 (P2a)
  derived              Boolean      @default(false) // 팀 파생(팀원 몫) — 읽기전용(입금 기록만 가능)
  businessId           String? // 상대 사업장 (가입 시)
  counterpartyName     String? // 상대 수기명 (미가입) — 파생 항목은 반장 이름
  amount               Decimal      @db.Decimal(12, 2) // 받을 금액
  dueDate              DateTime? // 수금 예정일
  status               LedgerStatus @default(PENDING)
  payments             Json[]       @default([]) // 입금 기록 [{ amount, paidAt, method }] (부분입금)
  // 수금 독촉 자동화 (P3a)
  autoRemind           Boolean      @default(false) // 자동 수금 안내 ON/OFF (파생 항목 제외)
  reminders            Json[]       @default([]) // 발송 이력 [{ at, channel, stage }] stage: D7|D30|MANUAL
  taxInvoicedAt        DateTime? // 세금계산서 발행(홈택스 입력) 완료 표시 시각 — 재집계 제외용
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  profile            Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  confirmation       Confirmation? @relation("LedgerConfirmation", fields: [confirmationId], references: [id], onDelete: SetNull)
  sourceConfirmation Confirmation? @relation("LedgerSourceConfirmation", fields: [sourceConfirmationId], references: [id], onDelete: SetNull)
  business           Business?     @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([profileId])
  @@index([businessId])
  @@index([dueDate])
  @@index([sourceConfirmationId]) // 팀 확인서 → 팀원 파생 항목 조회
  @@map("ledger_entries")
}

// ============================================================================
//  safety_logs — 안전 증빙 (APPEND-ONLY)
//   ⚠️ 증거력 원칙: 이 테이블의 레코드는 생성 후 UPDATE / DELETE 하지 않는다.
//      상태 변화(발송→수신→확인)는 기존 레코드 수정이 아니라, 각 시점 필드에
//      값을 append 하는 방식으로만 기록한다. updatedAt 컬럼을 두지 않는다.
//      (application 레벨에서 update/delete 금지, 시각은 서버 기준으로만 기록)
// ============================================================================
model SafetyLog {
  id              String        @id @default(uuid())
  type            SafetyLogType // 유형
  targetProfileId String // 대상자
  businessId      String? // 관련 사업장 (사업장 안전 리포트 집계용, 미가입/개인은 null)
  payload         Json? // 알림 내용(폭염 기준/문구 등)
  sentAt          DateTime? // 발송 시각
  receivedAt      DateTime? // 수신 시각
  confirmedAt     DateTime? // 확인 시각
  ackAt           DateTime? // 작업자 "확인" 시각 (append-only 예외: 최초 1회만 UPDATE 허용)
  createdAt       DateTime      @default(now())
  // 주의: updatedAt 없음 — append-only 설계 (ackAt 만 최초 1회 UPDATE)

  target   Profile   @relation("SafetyTarget", fields: [targetProfileId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([targetProfileId])
  @@index([type])
  @@index([businessId]) // 사업장별 안전 리포트 집계
  @@map("safety_logs")
}

// ============================================================================
//  otp_codes — 전화번호 인증 코드 (DB 저장: 서버 재시작에도 유지)
//   - 단일 인스턴스 전제. code 는 bcrypt 해시로만 저장(평문 저장 금지).
//   - 만료 3분 / 시도 5회 제한 / 재요청 쿨다운 30초는 애플리케이션 레벨에서 강제.
// ============================================================================
model OtpCode {
  id        String   @id @default(uuid())
  phone     String // 인증 대상 전화번호
  codeHash  String // 6자리 코드의 bcrypt 해시
  expiresAt DateTime // 만료 시각 (발급 + 3분)
  attempts  Int      @default(0) // 검증 시도 횟수 (5회 초과 차단)
  verified  Boolean  @default(false) // 검증 완료 여부 (재사용 방지)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([expiresAt])
  @@map("otp_codes")
}

// ============================================================================
//  notifications — 알림
// ============================================================================
model Notification {
  id        String           @id @default(uuid())
  profileId String
  type      NotificationType
  title     String
  body      String
  data      Json? // 딥링크/참조 id 등
  readAt    DateTime? // 읽음 시각 (null = 미읽음)
  createdAt DateTime         @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([type])
  @@map("notifications")
}

// ============================================================================
//  device_tokens — FCM 디바이스 토큰
// ============================================================================
model DeviceToken {
  id        String         @id @default(uuid())
  profileId String
  token     String         @unique // FCM 토큰
  platform  DevicePlatform
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("device_tokens")
}

// ============================================================================
//  teams — 반장(팀장)의 팀 (P2a)
//   - 반장 1명(ownerId=profile)이 여러 팀을 소유할 수 있다.
//   - 팀원(team_members)은 가입자(연결) 또는 수기(이름+전화) 둘 다 허용.
// ============================================================================
model Team {
  id        String   @id @default(uuid())
  ownerId   String // 반장(팀장) profileId
  name      String // 팀 이름
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner         Profile        @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       TeamMember[]
  confirmations Confirmation[]

  @@index([ownerId])
  @@map("teams")
}

// ============================================================================
//  team_members — 팀원 명단 (P2a)
//   - profileId 있으면 가입자(전화 검색-동의자- 연결). 없으면 수기(name+phone).
//   - defaultRate: 팀 확인서 작성 시 자동 채워지는 기본 단가(공수 1일 단가).
// ============================================================================
model TeamMember {
  id          String   @id @default(uuid())
  teamId      String
  profileId   String? // 가입자(연결)일 때만
  name        String // 표시 이름 (가입자면 이름 스냅샷, 수기면 입력값)
  phone       String? // 수기 전화(미가입) 또는 연결 참고
  defaultRate Decimal? @db.Decimal(12, 2) // 기본 단가(공수 1일 단가) — 확인서 작성 시 자동
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team    Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  profile Profile? @relation("TeamMemberProfile", fields: [profileId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([profileId])
  @@map("team_members")
}

// ============================================================================
//  labor_contracts — 표준근로계약서 (P2b)
//   - 고용노동부 일용직 표준근로계약서 필드 기반. 사업장(발행) ↔ 작업자(서명) 양자.
//   - 작업자: 가입자(workerProfileId 연결) 또는 수기(workerName + workerPhone).
//   - 서명: 사업장 대표 서명(먼저) → 전송(SENT) → 작업자 서명(공개 링크 or 앱) → SIGNED.
//   - 서명 기록(이미지 경로/서명자명/시각)은 서버 시각 기준. 양측 PDF 보관.
//   - 정본 안내: 웹/PDF 에 "본 계약서의 정본은 한국어본입니다" 문구 렌더(다국어 열람).
// ============================================================================
model LaborContract {
  id         String   @id @default(uuid())
  businessId String // 발행 사업장 (사업장 모드 소유자가 작성)
  title      String   @default("표준근로계약서") // 문서 제목

  // 작업자(근로자) — 가입 연결 또는 수기
  workerProfileId String? // 가입 작업자(연결)일 때만 — 서류 지갑 "내 계약서" 자동 연결
  workerName      String // 작업자 성명 (가입자면 스냅샷, 수기면 입력값)
  workerPhone     String? // 작업자 연락처 (수기 발송/알림톡용)

  // 계약 기간 — 종료일 없으면 일 단위/기간의 정함 없음
  startDate DateTime // 계약 시작일 (근로개시일)
  endDate   DateTime? // 계약 종료일 (일용/단기면 시작일과 동일하거나 null)

  // 근무 조건
  workplace      String // 근무 장소
  jobDescription String // 업무 내용
  workStartTime  String // 시업 시각 HH:mm
  workEndTime    String // 종업 시각 HH:mm
  breakTime      String? // 휴게 시간 (예: "12:00~13:00 60분")

  // 임금
  wageType             WageType // 일급(DAILY) / 시급(HOURLY)
  wageAmount           Decimal   @db.Decimal(12, 2) // 금액(일당/시급)
  payday               String // 임금 지급일 (예: "매월 말일", "작업 종료 시")
  payMethod            String // 지급 방법 (예: "근로자 명의 계좌 입금")
  weeklyHolidayAllowance Boolean @default(false) // 주휴수당 지급 문구 포함
  overtimeAllowance      Boolean @default(true) // 연장·야간·휴일근로 가산수당 문구 포함

  // 4대보험 적용 체크 { employment, health, pension, industrialAccident }
  socialInsurance Json?

  specialTerms String? // 특약사항

  // 사업장(사용자) 서명 — 전송 전 필수 선행
  employerSignImagePath String? // 서명 이미지 경로
  employerSignerName    String? // 사업장 대표자명(서명자)
  employerSignedAt      DateTime? // 사업장 서명 시각(서버 기준)

  // 작업자(근로자) 서명 — 공개 링크 or 앱 내
  workerSignImagePath String? // 서명 이미지 경로
  workerSignerName    String? // 작업자 서명자명
  workerSignedAt      DateTime? // 작업자 서명 시각(서버 기준)

  // 공개 링크 / 열람
  shareToken String              @unique // 외부 링크 토큰
  revokedAt  DateTime? // 링크 무효화 시각
  viewLogs   Json[]              @default([]) // 공개 열람 로그 [{ at, ip, ua }] — 최근 50개만 유지
  viewCount  Int                 @default(0) // 누적 열람 횟수
  status     LaborContractStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  workerProfile Profile? @relation("LaborContractWorker", fields: [workerProfileId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([workerProfileId]) // 작업자 "내 계약서" 조회
  @@index([status])
  @@map("labor_contracts")
}

// ============================================================================
//  tbm_records — 간편 TBM(툴박스 미팅/안전점검회의) 기록 (P2c)
//   - 사업장 소유자가 현장 TBM 을 기록. 당일 수정 허용, 이후 읽기전용(증빙 무결성).
//   - 위험요인(hazards)은 키 기반 JSON 배열 [{ code?, text? }]:
//       code = 기본 프리셋 코드(작업자에게 자기 언어로 번역 표시),
//       text = 사업장 커스텀/직접입력 문구(원문 그대로).
//   - measures(조치), notes(특이사항)는 자유 텍스트. photoPaths 는 현장 사진.
// ============================================================================
model TbmRecord {
  id               String   @id @default(uuid())
  businessId       String // 기록 사업장 (소유자만 작성)
  authorProfileId  String? // 작성자(사업장 소유자) — 참고용, 삭제 시 SetNull
  site             String // 현장명/장소
  occurredAt       DateTime // TBM 실시 일시
  hazards          Json     @default("[]") // 위험요인 [{ code?, text? }]
  measures         String? // 안전 조치 (자유 텍스트)
  notes            String? // 특이사항
  photoPaths       String[] @default([]) // 현장 사진 경로들
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business  Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  author    Profile?      @relation("TbmAuthor", fields: [authorProfileId], references: [id], onDelete: SetNull)
  attendees TbmAttendee[]

  @@index([businessId])
  @@index([businessId, occurredAt]) // 월간 리포트 집계
  @@map("tbm_records")
}

// ============================================================================
//  tbm_attendees — TBM 참석자 (P2c)
//   - profileId 있으면 가입 작업자(연결/동의자). 없으면 수기(name).
//   - ackAt: 참석자 "확인" 시각 (append-only 예외: 최초 1회만 UPDATE, 재확인 409).
// ============================================================================
model TbmAttendee {
  id        String    @id @default(uuid())
  recordId  String
  profileId String? // 가입 작업자(연결)일 때만
  name      String // 표시 이름 (가입자면 스냅샷, 수기면 입력값)
  ackAt     DateTime? // 참석자 확인 시각 (서버 기준, 최초 1회)
  createdAt DateTime  @default(now())

  record  TbmRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  profile Profile?  @relation("TbmAttendeeProfile", fields: [profileId], references: [id], onDelete: SetNull)

  @@index([recordId])
  @@index([profileId]) // 작업자 "받은 TBM" 조회
  @@map("tbm_attendees")
}

// ============================================================================
//  tbm_presets — 사업장별 자주 쓰는 TBM 문구 프리셋 (P2c)
//   - 커스텀 문구만 저장(원문). 기본 프리셋(건설 현장 일반)은 코드 기반으로
//     클라이언트가 6언어 번역해 노출하므로 DB 에 두지 않는다.
// ============================================================================
model TbmPreset {
  id         String        @id @default(uuid())
  businessId String
  kind       TbmPresetKind // HAZARD | MEASURE
  text       String // 프리셋 문구(원문)
  createdAt  DateTime      @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("tbm_presets")
}
