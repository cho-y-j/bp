# ===== 작업온 백엔드 환경변수 예시 =====
# 실제 값은 .env 파일에 복사해서 채운다 (.env 는 커밋 금지).

# --- 서버 ---
NODE_ENV=development
PORT=3000

# --- 데이터베이스 (PostgreSQL 16) ---
# 로컬 개발: infra/docker-compose.dev.yml 의 postgres 접속 정보와 일치시킨다.
DATABASE_URL="postgresql://jakeobon:jakeobon@localhost:5432/jakeobon?schema=public"

# --- 인증 (JWT) : S2 에서 사용 ---
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# --- 카카오 로그인 (S2) ---
# 미설정(false)이면 /auth/kakao 는 501 스텁으로 응답한다. 실연동 시 true 로.
KAKAO_ENABLED=false

# --- CORS (웹 오리진) ---
WEB_ORIGIN="http://localhost:3001"

# --- 파일 저장 경로 (S2 업로드에서 사용) ---
UPLOAD_DIR="./uploads"
# 업로드 최대 크기(바이트). 기본 20MB.
MAX_UPLOAD_BYTES=20971520

# --- 서류 공유 링크 (S2b) ---
# 외부(미가입자) 공유 링크 베이스 URL. /s/{token} 이 뒤에 붙는다.
PUBLIC_WEB_URL="http://localhost:3001"

# --- 사업자등록 진위확인 (공공데이터포털 국세청, S2b) ---
# 미설정이면 /documents/:id/verify (사업자등록증) 은 501 스텁으로 응답한다.
# 발급: https://www.data.go.kr → "국세청_사업자등록정보 진위확인 및 상태조회 서비스"
GOV_DATA_SERVICE_KEY=""

# --- 폭염 안전 알림 (기상청 단기예보, S2d) ---
# 공공데이터포털 "기상청_단기예보 조회서비스" 서비스키. 미설정이면 폭염 스캔 비활성(로그만).
KMA_SERVICE_KEY=""

# --- FCM 푸시 (S2d) ---
# firebase 서비스계정 JSON 파일 경로. 미설정이면 푸시는 로그만(레코드는 생성).
FCM_SERVICE_ACCOUNT_PATH=""

# --- 카카오 알림톡 (P1, Solapi 어댑터) ---
# 아래 4개(KEY/SECRET/SENDER/PFID) 가 모두 있어야 알림톡 활성. 없으면 로그만.
# 운영 발송 전 카카오 비즈메시지 센터에서 발신 프로필·템플릿 심사 승인이 필요하다.
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
ALIMTALK_SENDER=""            # 사전 등록된 발신번호(대체문자용)
ALIMTALK_PFID=""             # 카카오 발신 프로필(채널) ID
# 승인 완료 후 발급된 templateId 를 템플릿별로 주입(없으면 해당 템플릿 발송 건너뜀).
ALIMTALK_TEMPLATE_CONFIRMATION_SIGN=""
ALIMTALK_TEMPLATE_PAYMENT_DUE=""
ALIMTALK_TEMPLATE_PAYMENT_REMINDER=""
ALIMTALK_TEMPLATE_HEAT_ALERT=""
