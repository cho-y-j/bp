# ============================================================================
#  작업온 통합 스택(.env) — 이 파일을 저장소 루트에 `.env` 로 복사해 값을 채운다.
#  (docker compose 가 루트 .env 를 읽는다. 절대 커밋 금지.)
#  각 변수의 발급 절차는 docs/DEPLOY.md 참고.
# ============================================================================

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_USER=jakeobon
# 강한 비밀번호 생성:  openssl rand -hex 16
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=jakeobon

# --- 인증(JWT) -------------------------------------------------------------
# 반드시 교체! (미교체·약한 값이면 production api 기동 실패 fail-fast)
# 생성:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-64-char-random-secret
JWT_EXPIRES_IN=7d

# --- 공개 도메인 -----------------------------------------------------------
# 브라우저 CORS 허용 오리진(운영 도메인). 예) https://jakeobon.example.com
WEB_ORIGIN=https://your-domain.example.com
# 카톡 공유 링크 등에 박히는 공개 웹 주소(WEB_ORIGIN 과 보통 동일).
PUBLIC_WEB_URL=https://your-domain.example.com

# --- 외부 연동 키 (없으면 해당 기능은 비활성 스텁) -------------------------
# 사업자등록 진위확인: 공공데이터포털 국세청 서비스키
GOV_DATA_SERVICE_KEY=
# 폭염 안전 알림: 기상청 단기예보 조회서비스 서비스키
KMA_SERVICE_KEY=
# 카카오 로그인 활성화(true/false). 실연동 준비 전까지 false 유지.
KAKAO_ENABLED=false
# FCM 푸시: 컨테이너 내부 서비스계정 JSON 경로. 파일은 infra/secrets/ 에 두고 마운트.
# 예) FCM_SERVICE_ACCOUNT_PATH=/app/secrets/fcm.json
FCM_SERVICE_ACCOUNT_PATH=
